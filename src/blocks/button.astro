---
import Arrow from "../assets/images/arrow.svg";

interface Props {
	text: string;
	href?: string;
	target?: string;
	class?: string;
	[key: string]: any;
}

const { text, href, target, class: className, ...rest } = Astro.props;
const isAbsolute = href ? href.startsWith("http://") || href.startsWith("https://") : false;
const finalUrl = href ? (isAbsolute ? href : `${import.meta.env.BASE_URL}${href}`) : undefined;
const finalTarget = target || (isAbsolute ? "_blank" : undefined);
const arrow = className?.includes("arrow");
---

<a class={`button${className ? " " + className : ""}`} href={finalUrl} target={finalTarget} {...rest}>
	<div>{text}</div>
	{
		arrow && (
			<div class="icon">
				<Arrow width={64} height={64} />
			</div>
		)
	}
</a>

<style>
	.button {
		--color-bg: var(--c-template);
		display: inline-grid;
		align-items: center;
		align-self: start;
		gap: 1.25em;
		color: var(--c-white);
		background: oklch(from var(--color-bg) l c h / 1);
		padding-inline: 1.25em;
		padding-block: 0.25em;
		text-align: center;
		min-height: calc(2.5em + 0.25em + 0.55em);
		border: solid var(--color-bg) 0.15em;
		font-variation-settings: "wght" 350;
		transition: background-color 0.2s ease-in-out;

		@container (width <= 450px) {
			& {
				width: 100%;
			}
		}

		&.arrow {
			grid-template-columns: 1fr minmax(0, auto);
			padding-inline-end: 0.275em;

			.icon {
				height: 2.5em;
				aspect-ratio: 1;
				padding: 0.75em;
				border-radius: 50%;
				background: var(--c-black);
				transition: 0.2s ease-in-out;

				svg {
					stroke: var(--c-white);
				}
			}
		}

		&.round {
			border-radius: 2em;
		}

		&.blue {
			--color-bg: var(--c-blue);
		}
		&.red {
			--color-bg: var(--c-red);
		}
		&.green {
			--color-bg: var(--c-green);
		}
		&.yellow {
			--color-bg: var(--c-yellow);
			color: var(--c-black);
		}
		&.orange {
			--color-bg: var(--c-orange);
		}
		&.pink {
			--color-bg: var(--c-pink);
			color: var(--c-black);
		}
		&.black {
			--color-bg: var(--c-black);
		}
		&.gray {
			--color-bg: var(--c-white);
		}

		&.outline {
			background-color: transparent;
			color: light-dark(var(--c-black), var(--c-white));

			.icon {
				background: var(--color-bg);
			}
		}

		&:hover {
			background: oklch(from var(--color-bg) calc(l - 0.125) c h / 1);

			.round & {
				color-scheme: dark;
			}

			.icon {
				scale: -1.3;
				rotate: 1turn;
				background: oklch(from var(--color-bg) 1 0 h / 1);

				svg {
					stroke: oklch(from var(--color-bg) 0 0 h / 1);
				}
			}
		}
	}
</style>
