---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import LayoutDefault from "../layouts/layoutdefault.astro";

import FormattedDate from "../blocks/date.astro";

import Link from "../blocks/link.astro";
import Button from "../blocks/button.astro";

import Book from "../assets/images/book.svg";
import Snow from "../assets/images/snow.svg";
import Wave from "../assets/images/wave.svg";
import Circle from "../assets/images/circle.svg";
import Splash from "../assets/images/splash.svg";
import Pointer from "../assets/images/pointer.svg";
import Star from "../assets/images/star.svg";

const posts = (await getCollection("insights")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Home";
const description = "My Description";
const image = "../assets/images/star.svg";
---

<LayoutDefault title={title} description={description} image={image}>
	<section class="dark">
		<div class="wrapper banner-intro">
			<div class="grid g-center-y">
				<h1 class="fs-6 uppercase bold">
					Let's <span style="color:var(--c-red)">talk</span><br /> about it
				</h1>
			</div>
			<div class="grid-icons">
				<div>
					<Wave class="animate" stroke="var(--c-blue)" width={64} height={64} />
				</div>
				<div>
					<Splash class="animate" width={64} height={64} fill="var(--c-yellow)" />
					<Book class="animate" width={64} height={64} stroke="var(--c-green)" />
				</div>
				<div>
					<Star class="animate" width={64} height={64} fill="var(--c-red)" />
					<Circle class="animate" width={64} height={64} stroke="var(--c-orange)" />
				</div>
				<div>
					<Snow class="animate" width={64} height={64} stroke="var(--c-yellow)" />
					<Pointer class="animate" width={64} height={64} stroke="var(--c-blue)" />
				</div>
			</div>
		</div>
		<div class="tilt edge move gb center uppercase fs-3 bold balance">&nbsp;</div>
	</section>

	<section>
		<div class="wrapper">
			<ul role="list" class="grid-blogs">
				{
					posts.map((post) => (
						<li role="listitem">
							<Link href={`insights/${post.id}/`} data-cat={post.data.category}>
								<div class="hero">
									<Image src={post.data.image as any} format="avif" layout="constrained" alt="" />
									<span class="category">{post.data.category}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<div class="excerpt">
									<h4 class="title">{post.data.title}</h4>
								</div>
							</Link>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="dark">
		<div class="wrapper grid g-center g-gap">
			<h2 class="balance fs-4 center">
				You've seen how <span style="color:var(--c-red)">we think.</span> Now let's talk about what we can <span
					style="color:var(--c-red)">build together.</span
				>
			</h2>
			<Button href="https://connect.inkfish.co.za/hello/" class="red round arrow" text="Let's talk" />
		</div>
	</section>
</LayoutDefault>
