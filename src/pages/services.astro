---
import LayoutDefault from "../layouts/layoutdefault.astro";
import Button from "../blocks/button.astro";

import Book from "../assets/images/book.svg";
import Snow from "../assets/images/snow.svg";
import Arrow from "../assets/images/arrow.svg";
import Arch from "../assets/images/arch.svg";
import Wave from "../assets/images/wave.svg";
import Circle from "../assets/images/circle.svg";
import Splash from "../assets/images/splash.svg";
import Pointer from "../assets/images/pointer.svg";
import Star from "../assets/images/star.svg";

const title = "Home";
const description = "My Description";
---

<LayoutDefault title={title} description={description}>
	<section class="dark">
		<div class="wrapper banner-intro">
			<div class="grid g-gap g-start">
				<h1 class="fs-6 uppercase bold balance trim">
					What you need. All in <span style="color:var(--c-orange)">one team.</span>
				</h1>
				<p>
					You don't need five different freelancers or three part-time marketers. You need one sharp, proactive team
					that handles it all. Strategy, content, design, websites, ads, and reporting.
				</p>
				<span class="pill green br-e fs-3"> That's us </span>
			</div>
			<div class="grid-icons">
				<div>
					<Book class="animate" stroke="var(--c-pink)" width={64} height={64} />
				</div>
				<div>
					<Wave class="animate" stroke="var(--c-orange)" width={64} height={64} />
					<Splash class="animate" fill="var(--c-blue)" width={64} height={64} />
				</div>
				<div>
					<Arrow class="animate" stroke="var(--c-green)" width={64} height={64} />
					<Circle class="animate" stroke="var(--c-red)" width={64} height={64} />
					<Snow class="animate" stroke="var(--c-yellow)" width={64} height={64} />
				</div>
				<div>
					<Arch class="animate" stroke="var(--c-yellow)" width={64} height={64} />
					<Pointer class="animate" stroke="var(--c-orange)" width={64} height={64} />
					<Star class="animate" fill="var(--c-blue)" width={64} height={64} />
				</div>
			</div>
		</div>
		<div class="tilt edge move pr center uppercase fs-3 bold balance">&nbsp;</div>
	</section>

	<section>
		<div class="wrapper">
			<ul role="list" class="grid-services">
				<li class="card">
